# yarad daemon environment. systemd reads this via EnvironmentFile.
# Every value here is also the built-in default — uncomment to override.
# Full reference: README.md "Configuration".

# --- listener ---
#YARAD_HOST=0.0.0.0
#YARAD_PORT=8079

# --- rules ---
# Cache dir `yarad fetch-rules` writes to (must match the -cache-dir you fetch
# with). Set it so /version surfaces the fetched manifest and the feed
# warm-start snapshots are enabled — leaving it unset disables both.
YARAD_CACHE_DIR=/var/cache/yarad
# The compiled bundle to load. The rolling .yac dropped by `yarad fetch-rules`
# (or the maintenance cron) into the cache dir above; a precompiled .yac wins
# over YARAD_RULES_DIR. Recommended .deb setup.
YARAD_RULES=/var/cache/yarad/compiled.yac
# Alternatively compile a directory of your own *.yar/*.yara on boot + SIGHUP:
#YARAD_RULES_DIR=/var/lib/yarad/rules
# Past this age (seconds) the ruleset is flagged stale: yarad_rules_stale=1 and
# /ready reports "ready (stale rules)" — still HTTP 200, the daemon keeps
# serving the last good rules; alert on the metric. Catches a broken refresh.
#YARAD_RULES_MAX_AGE=172800

# --- auth (recommended for non-trusted networks) ---
# Shared secret for /scan (and /metrics + /version when YARAD_METRICS_AUTH=1).
# Unset = OPEN /scan (trusted-network deployment, logged loudly at startup).
#YARAD_TOKEN=
#YARAD_METRICS_AUTH=0

# --- live IOC feeds (off unless enabled) ---
# URLhaus, MalwareBazaar and ThreatFox enable by setting their abuse.ch
# Auth-Key (one key works for all three); no key = feed off. Feodo needs no
# key and enables with =1.
#YARAD_URLHAUS_KEY=
#YARAD_MBAZAAR_KEY=
#YARAD_THREATFOX_KEY=
#YARAD_FEODO=1

# --- effort / backpressure ---
#YARAD_EFFORT=auto
#YARAD_MAX_INFLIGHT=32
#YARAD_MAX_BODY=33554432

# --- verdict cache TTL (seconds) ---
#YARAD_CACHE_TTL=3600

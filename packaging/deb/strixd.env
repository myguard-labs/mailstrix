# strixd daemon environment. systemd reads this via EnvironmentFile.
# Every value here is also the built-in default — uncomment to override.
# Full reference: README.md "Configuration".

# --- listener ---
#MAILSTRIX_HOST=0.0.0.0
#MAILSTRIX_PORT=8079

# --- rules ---
# Cache dir `strixd fetch-rules` writes to (must match the -cache-dir you fetch
# with). Set it so /version surfaces the fetched manifest and the feed
# warm-start snapshots are enabled — leaving it unset disables both.
MAILSTRIX_CACHE_DIR=/var/cache/mailstrix
# The compiled bundle to load. The rolling .yac dropped by `strixd fetch-rules`
# (or the maintenance cron) into the cache dir above; a precompiled .yac wins
# over MAILSTRIX_RULES_DIR. Recommended .deb setup.
MAILSTRIX_RULES=/var/cache/mailstrix/compiled.yac
# Alternatively compile a directory of your own *.yar/*.yara on boot + SIGHUP:
#MAILSTRIX_RULES_DIR=/var/lib/mailstrix/rules
# Past this age (seconds) the ruleset is flagged stale: mailstrix_rules_stale=1 and
# /ready reports "ready (stale rules)" — still HTTP 200, the daemon keeps
# serving the last good rules; alert on the metric. Catches a broken refresh.
#MAILSTRIX_RULES_MAX_AGE=172800

# --- auth (recommended for non-trusted networks) ---
# Shared secret for /scan (and /metrics + /version when MAILSTRIX_METRICS_AUTH=1).
# Unset = OPEN /scan (trusted-network deployment, logged loudly at startup).
#MAILSTRIX_TOKEN=
#MAILSTRIX_METRICS_AUTH=0

# --- live IOC feeds (off unless enabled) ---
# URLhaus, MalwareBazaar and ThreatFox enable by setting their abuse.ch
# Auth-Key (one key works for all three); no key = feed off.
#MAILSTRIX_URLHAUS_KEY=
#MAILSTRIX_MBAZAAR_KEY=
#MAILSTRIX_THREATFOX_KEY=

# --- effort / backpressure ---
#MAILSTRIX_EFFORT=auto
#MAILSTRIX_MAX_INFLIGHT=32
#MAILSTRIX_ICAP_MAX_CONNS=256
#MAILSTRIX_MAX_BODY=33554432

# --- scoring policy ---
# Canary/shadow mode: return matches as log-only metadata so shipped integrations
# observe but do not score/block them.
#MAILSTRIX_CANARY=0

# --- verdict cache TTL (seconds) ---
#MAILSTRIX_CACHE_TTL=3600
